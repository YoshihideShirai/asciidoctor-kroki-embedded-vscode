{
  "name": "asciidoctor-kroki-embedded-vscode",
  "displayName": "Asciidoctor Kroki Embedded Helper",
  "description": "Registers asciidoctor-kroki-embedded with asciidoctor-vscode preview and export workflows.",
  "version": "1.0.0",
  "license": "MIT",
  "publisher": "yoshihideshirai",
  "repository": {
    "type": "git",
    "url": "https://github.com/YoshihideShirai/asciidoctor-kroki-embedded-vscode.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:asciidoc"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "asciidoc.asciidoctorExtensions": true,
    "asciidoc.previewStyles": [
      "dist/kroki-embedded.css"
    ],
    "asciidoc.previewScripts": [
      "dist/plantuml-viz-global.js",
      "dist/preview.js"
    ],
    "configuration": {
      "title": "Asciidoctor Kroki Embedded",
      "properties": {
        "asciidoctorKrokiEmbedded.defaultFormat": {
          "type": "string",
          "default": "svg",
          "description": "Default diagram format passed to asciidoctor-kroki-embedded."
        },
        "asciidoctorKrokiEmbedded.diagramNames": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Diagram block and macro names to register. Leave empty to use the package defaults except Mermaid. Mermaid is always excluded."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run bundle",
    "bundle": "npm run bundle:assets && npm run bundle:extension && npm run bundle:preview",
    "bundle:assets": "mkdir -p dist && cp node_modules/@plantuml/core/viz-global.js dist/plantuml-viz-global.js && cp node_modules/asciidoctor-kroki-embedded/src/style.css dist/kroki-embedded.css",
    "bundle:extension": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node20 --external:vscode --outfile=dist/extension.js --sourcemap",
    "bundle:preview": "esbuild src/preview.ts --bundle --platform=browser --format=iife --target=es2020 --outfile=dist/preview.js --sourcemap",
    "check": "tsc -p . --noEmit",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "@plantuml/core": "^1.2026.6",
    "asciidoctor-kroki-embedded": "github:YoshihideShirai/asciidoctor-kroki-embedded#v0.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.2"
  }
}
